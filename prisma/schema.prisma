generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())

  auditLogs AuditLog[]
}

enum AdminRole {
  ADMIN
  SUPPORT
}

enum ProfileStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum AssignmentStatus {
  ACTIVE
  EXPIRED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model Customer {
  id               String         @id @default(uuid())
  name             String
  phone            String         @unique
  status           CustomerStatus @default(ACTIVE)
  lastReminderSent DateTime?
  createdAt        DateTime       @default(now())

  orders     Order[]
  accessLogs AccessLog[]
  notifications Notification[]

  @@index([phone])
  @@index([status])
}

model Notification {
  id         String   @id @default(uuid())
  customerId String
  type       String   // e.g. "EXPIRATION_WARNING", "RENEWAL_CONFIRMATION"
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
}

model StreamingService {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  bannerUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  offers   ProductOffer[]
  accounts StreamingAccount[]
}

model ProductOffer {
  id             String   @id @default(uuid())
  serviceId      String
  name           String
  price          Decimal  @db.Decimal(10, 2)
  durationInDays Int
  createdAt      DateTime @default(now())

  service StreamingService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@index([serviceId])
}

model StreamingAccount {
  id        String   @id @default(uuid())
  serviceId String
  email     String
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  service  StreamingService   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  profiles StreamingProfile[]

  @@index([serviceId])
  @@index([email])
}

model StreamingProfile {
  id          String        @id @default(uuid())
  accountId   String
  profileName String
  pin         String?
  status      ProfileStatus @default(AVAILABLE)
  isAvailable Boolean       @default(true)
  expiresAt   DateTime?
  isExpired   Boolean       @default(false)
  createdAt   DateTime      @default(now())

  account     StreamingAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assignments ProfileAssignment[]

  @@index([accountId])
  @@index([status])
  @@index([isExpired])
}

model Order {
  id            String        @id @default(uuid())
  customerId    String
  offerId       String
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  proofImageUrl String
  createdAt     DateTime      @default(now())

  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  offer    ProductOffer @relation(fields: [offerId], references: [id])

  assignment ProfileAssignment?

  @@index([customerId])
  @@index([offerId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  EMOLA
  MPESA
  BCI
  BIM
}

enum RenewalStatus {
  NONE
  PENDING
  RENEWED
  EXPIRED
}

model ProfileAssignment {
  id                         String           @id @default(uuid())
  orderId                    String           @unique
  profileId                  String
  status                     AssignmentStatus @default(ACTIVE)
  isExpired                  Boolean          @default(false)
  expiresAt                  DateTime
  renewalStatus              RenewalStatus    @default(NONE)
  renewedAt                  DateTime?
  expirationNotificationSent Boolean          @default(false)
  createdAt                  DateTime         @default(now())

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  profile StreamingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([expiresAt])
  @@index([renewalStatus])
  @@index([status])
  @@index([isExpired])
  @@index([renewedAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  adminUserId String?
  action      String
  resource    String
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model AccessLog {
  id         String   @id @default(uuid())
  customerId String?
  path       String
  method     String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([path])
  @@index([createdAt])
}

model SecurityEvent {
  id        String   @id @default(uuid())
  eventType String
  severity  String
  message   String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

model WhatsappMessageLog {
  id             String        @id @default(uuid())
  to             String
  content        String
  status         MessageStatus @default(PENDING)
  deliveryStatus String?       // From API (e.g. "delivered", "read")
  retryCount     Int           @default(0)
  lastAttemptAt  DateTime?
  error          String?
  metadata       Json?         // To store orderId, etc.
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([to])
}
