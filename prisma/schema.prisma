generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
}

enum AdminRole {
  ADMIN
  SUPPORT
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  orders Order[]

  @@index([phone])
}

model Service {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  plans    Plan[]
  accounts Account[]
}

model Plan {
  id             String   @id @default(uuid())
  serviceId      String
  name           String
  price          Decimal  @db.Decimal(10, 2)
  durationInDays Int
  maxSlots       Int
  isShared       Boolean
  createdAt      DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@index([serviceId])
}

model Account {
  id             String   @id @default(uuid())
  serviceId      String
  email          String
  password       String
  totalSlots     Int
  availableSlots Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  service Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  assignments OrderAssignment[]

  @@index([serviceId])
  @@index([email])
}

model Order {
  id            String        @id @default(uuid())
  customerId    String
  planId        String
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  proofImageUrl String
  createdAt     DateTime      @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan     Plan     @relation(fields: [planId], references: [id])

  assignment OrderAssignment?

  @@index([customerId])
  @@index([planId])
  @@index([status])
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  EMOLA
  MPESA
  BCI
  BIM
}

model OrderAssignment {
  id         String   @id @default(uuid())
  orderId    String   @unique
  accountId  String
  slotNumber Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

